{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Demido Studio",
  "version": "0.1.0",
  "identifier": "studio.demido.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Demido Studio",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "AI chat for everyone",
    "longDescription": "Open-source desktop AI chat with local model support, multi-provider switching, and MCP tool integration.",
    "category": "Productivity"
  }
}
