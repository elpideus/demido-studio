{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Demido Studio",
  "version": "0.5.0",
  "identifier": "studio.demido.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Demido Studio",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "dragDropEnabled": false,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVEMEVDRTA0ODVDQUU3QTUKUldTbDU4cUZCTTRPWFhySXFwS2RlVkJEY3NUVHRhaVlCdVVYTzl1bXdrNERRdVE2Y1ZTb0l3WWcK",
      "endpoints": [
        "https://github.com/elpideus/demido-studio/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "AI chat for everyone",
    "longDescription": "Open-source desktop AI chat with local model support, multi-provider switching, and MCP tool integration.",
    "category": "Productivity"
  }
}
